{
  "name": "mud",
  "version": "0.1.0",
  "private": true,
  "description": "MUD scaffold for WeChat Mini Game with Cocos Creator v3.x",
  "scripts": {
    "start": "tsc --watch --preserveWatchOutput",
    "build": "tsc -p tsconfig.json",
    "build:wechat": "bash build-scripts/build-wechat.sh",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^22.8.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}